# Copy to terraform.tfvars (gitignored) and fill in. Do not commit real values.

# Allowlisted PUBLIC source CIDR(s) for WireGuard + admin SSH. Use your /32. Never 0.0.0.0/0.
allowed_ingress_cidrs = ["203.0.113.10/32"]

# Your SSH public key material (contents of ~/.ssh/id_ed25519.pub).
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Budget alert recipients.
budget_notification_emails = ["brian@example.com"]

# Optional overrides:
# enable_workload_hosts      = true
# enable_provisioning_egress = false
# gateway_instance_type      = "t3.micro"
# workload_instance_type     = "t3.small"
